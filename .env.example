# ========= 当前 API / Web 本地开发会用到 =========
NODE_ENV=development
PORT=18080
# 与本仓库 docker-compose / Makefile 保持一致：
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/sg
WEB_BASE_URL=http://127.0.0.1:3000
API_BASE_URL=http://127.0.0.1:18080
# 设置后 /v1/admin/* 需带 X-Admin-Key 或 Authorization: Bearer
ADMIN_API_KEY=

# JWT 签名密钥 — 生产环境务必设置随机值: openssl rand -base64 48
JWT_SECRET=change-me-in-production

# 列表「q」相关度：可选混合向量排序（无 key 则仅 pg_trgm）
OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Copilot Q&A：OpenAI chat 模型（默认 gpt-4o-mini）
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_CHAT_INPUT_COST_PER_1K=0.00015
# OPENAI_CHAT_OUTPUT_COST_PER_1K=0.0006

# Copilot Q&A：Anthropic Claude（优先于 OpenAI chat）
ANTHROPIC_API_KEY=
# ANTHROPIC_CHAT_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_CHAT_INPUT_COST_PER_1K=0.0008
# ANTHROPIC_CHAT_OUTPUT_COST_PER_1K=0.004
OPENSEARCH_URL=http://localhost:9200
TEMPORAL_ADDRESS=localhost:7233
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
