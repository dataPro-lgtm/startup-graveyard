{
  "name": "@sg/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "pretest": "pnpm --filter @sg/shared build",
    "test": "vitest run",
    "test:pg": "node scripts/run_pg_integration_tests.mjs",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/sensible": "^6.0.3",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.2",
    "@sg/shared": "workspace:*",
    "@types/pdfkit": "^0.17.5",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.1",
    "fastify": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.18.0",
    "pg": "^8.14.1",
    "stripe": "^22.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.4",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.0",
    "vitest": "^3.0.5"
  }
}
